<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="trampbazaar.Pages.RegisterPage"
             Title="Kayit Ol">

    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="16">
            <Label Text="Kayit Ol"
                   FontFamily="OpenSansSemibold"
                   FontSize="28" />

            <Entry Placeholder="Ad Soyad / Firma Adi"
                   Text="{Binding FullName}" />

            <Entry Placeholder="Kullanici adi"
                   Text="{Binding UserName}" />

            <Entry Placeholder="E-posta"
                   Keyboard="Email"
                   Text="{Binding Email}" />

            <Entry Placeholder="Sifre"
                   IsPassword="True"
                   Text="{Binding Password}" />

            <Picker x:Name="AccountTypePicker"
                    Title="Hesap tipi"
                    SelectedIndexChanged="OnAccountTypeChanged">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>individual</x:String>
                        <x:String>corporate</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Button Text="Kayit Ol"
                    Clicked="OnRegisterClicked" />

            <Border Padding="14"
                    BackgroundColor="#FFF1F2"
                    Stroke="#FECDD3"
                    IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#9F1239" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
