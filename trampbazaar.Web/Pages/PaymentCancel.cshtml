@page
@model trampbazaar.Web.Pages.PaymentCancelModel
@{
    ViewData["Title"] = "Odeme Iptal";
}

<section class="detail-shell wide-shell">
    <p class="eyebrow">Odeme Durumu</p>
    <h1>Odeme islemi tamamlanmadi.</h1>
    <p class="detail-copy">Odeme akisi iptal edildi veya yarim kaldi. Dilerseniz tekrar deneyebilirsiniz.</p>
    @if (Model.PaymentId.HasValue)
    {
        <p class="muted-copy">Odeme no: @Model.PaymentId</p>
    }
    <div class="hero-actions">
        <a class="primary-link" asp-page="/Packages">Tekrar Dene</a>
        <a class="secondary-link" asp-page="/Account">Hesabima Git</a>
    </div>
</section>
